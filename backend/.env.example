# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=plant-tracker

# OpenAI
OPENAI_API_KEY=sk-...

# OpenPlantbook (https://open.plantbook.io)
# Register at https://open.plantbook.io/registrations/
OPENPLANTBOOK_CLIENT_ID=your-client-id
OPENPLANTBOOK_CLIENT_SECRET=your-client-secret

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your-long-lived-access-token
# Entity ID of the indicator light to change color on alerts (optional)
HA_INDICATOR_LIGHT_ENTITY=light.plant_indicator
# HA notification service to call (e.g. notify.mobile_app_yourphone or notify.persistent_notification)
HA_NOTIFICATION_SERVICE=notify.persistent_notification
